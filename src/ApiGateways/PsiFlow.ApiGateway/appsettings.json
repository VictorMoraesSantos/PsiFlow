{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp.ReverseProxy": "Information"
    }
  },
  "AllowedHosts": "*",
  "JwtSettings": {
    "Key": "SuperSecretKeyForJWTAuthentication2024!@#$%",
    "Issuer": "PsiFlowAPI",
    "Audience": "PsiFlowApp",
    "ExpiryMinutes": 60
  },
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "AuthorizationPolicy": "Anonymous",
        "Match": {
          "Path": "/auth/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/auth" }
        ]
      },
      "patients-route": {
        "ClusterId": "patients-cluster",
        "AuthorizationPolicy": "Default",
        "Match": {
          "Path": "/patients/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/patients" }
        ]
      },
      "agenda-route": {
        "ClusterId": "agenda-cluster",
        "AuthorizationPolicy": "Default",
        "Match": {
          "Path": "/agenda/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/agenda" }
        ]
      },
      "sessions-route": {
        "ClusterId": "sessions-cluster",
        "AuthorizationPolicy": "Default",
        "Match": {
          "Path": "/sessions/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/sessions" }
        ]
      },
      "clinical-records-route": {
        "ClusterId": "clinical-records-cluster",
        "AuthorizationPolicy": "Default",
        "Match": {
          "Path": "/clinical-records/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/clinical-records" }
        ]
      },
      "notifications-route": {
        "ClusterId": "notifications-cluster",
        "AuthorizationPolicy": "Default",
        "Match": {
          "Path": "/notifications/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/notifications" }
        ]
      },
      "online-session-route": {
        "ClusterId": "online-session-cluster",
        "AuthorizationPolicy": "Default",
        "Match": {
          "Path": "/online-session/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/online-session" }
        ]
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "auth-api": {
            "Address": "http://localhost:5000/"
          }
        }
      },
      "patients-cluster": {
        "Destinations": {
          "patients-api": {
            "Address": "http://localhost:5002/"
          }
        }
      },
      "agenda-cluster": {
        "Destinations": {
          "agenda-api": {
            "Address": "http://localhost:5003/"
          }
        }
      },
      "sessions-cluster": {
        "Destinations": {
          "sessions-api": {
            "Address": "http://localhost:5004/"
          }
        }
      },
      "clinical-records-cluster": {
        "Destinations": {
          "clinical-records-api": {
            "Address": "http://localhost:5005/"
          }
        }
      },
      "notifications-cluster": {
        "Destinations": {
          "notifications-api": {
            "Address": "http://localhost:5006/"
          }
        }
      },
      "online-session-cluster": {
        "Destinations": {
          "online-session-api": {
            "Address": "http://localhost:5007/"
          }
        }
      }
    }
  }
}
