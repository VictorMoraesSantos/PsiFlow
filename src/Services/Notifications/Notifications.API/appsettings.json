{
  "Logging": { "LogLevel": { "Default": "Information", "Microsoft.AspNetCore": "Warning" } },
  "AllowedHosts": "*",
  "ConnectionStrings": { "Database": "Host=localhost;Port=5432;Database=psiflow_notifications;Username=psiflow;Password=psiflow_dev_password" },
  "JwtSettings": { "Issuer": "PsiFlowAPI", "Audience": "PsiFlowApp", "JwksUri": "http://localhost:5001/.well-known/jwks.json" },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File", "Serilog.Sinks.Seq", "Serilog.Exceptions", "Serilog.Enrichers.Environment", "Serilog.Enrichers.Process", "Serilog.Enrichers.Thread" ],
    "MinimumLevel": { "Default": "Information", "Override": { "Microsoft": "Warning", "Microsoft.AspNetCore": "Warning", "Microsoft.EntityFrameworkCore": "Warning", "System": "Warning" } },
    "Enrich": [ "FromLogContext", "WithMachineName", "WithEnvironmentName", "WithProcessId", "WithThreadId", "WithExceptionDetails" ],
    "Properties": { "Application": "PsiFlow.Notifications.API", "Service": "Notifications" },
    "WriteTo": [
      { "Name": "Console", "Args": { "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact" } },
      { "Name": "File", "Args": { "path": "Logs/notifications-api-.log", "rollingInterval": "Day", "retainedFileCountLimit": 14, "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact" } },
      { "Name": "Seq", "Args": { "serverUrl": "http://localhost:5341" } }
    ]
  }
}
